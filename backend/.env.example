# ══════════════════════════════════════════════════════
#  Medical Chatbot - Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git — it's in .gitignore
# ══════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use (gpt-3.5-turbo is cheaper; gpt-4 is more accurate)
OPENAI_MODEL=gpt-3.5-turbo

# ── Pinecone ─────────────────────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=your-pinecone-api-key-here

# Your Pinecone index name (create this in Pinecone dashboard first,
# OR the ingest script will auto-create it)
PINECONE_INDEX_NAME=medical-chatbot

# Pinecone cloud region (check your index details in dashboard)
PINECONE_ENV=us-east-1

# ── Flask Config ─────────────────────────────────────
# "development" enables debug mode and verbose logging
# "production" for Render deployment
FLASK_ENV=development
PORT=5000

# Allowed frontend origins for CORS
# In development: http://localhost:3000 or *
# In production: https://your-frontend.vercel.app
ALLOWED_ORIGINS=*

# ── LLM Settings ─────────────────────────────────────
# Lower temperature = more factual (0.0-0.5 recommended for medical)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
